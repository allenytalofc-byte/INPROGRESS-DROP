{
  "name": "dropship-monorepo",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "postinstall": "echo Monorepo installed",
    "migrate": "node infra/scripts/migrate.js",
    "seed": "node services/api/scripts/seed.js",
    "dev:api": "npm --workspace services/api run start:dev",
    "dev:store": "npm --workspace apps/store-frontend run dev",
    "dev:admin": "npm --workspace apps/admin-panel run dev",
    "build:api": "npm --workspace services/api run build",
    "build:store": "npm --workspace apps/store-frontend run build",
    "build:admin": "npm --workspace apps/admin-panel run build",
    "lint": "echo no linter configured"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.11.5"
  }
}